---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
	content: {
		title: string;
		description: string;
		pubDate?: string;
		updatedDate?: string;
		heroImage?: string;
		author?: string;
	};
}

const {
	content: { title, description, pubDate, updatedDate, heroImage, author },
} = Astro.props as Props;
---

<html>
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.title {
				font-size: 2em;
				margin: 0.25em 0 0;
			}
			hr {
  				border-top: 1px solid #DDD;
				margin: 1rem 0;
			}
		</style>
	</head>

	<body class="dark:bg-gray-900 dark:text-gray-100">
		<Header />
		<main class="mx-auto max-w-[50rem]">
			<article class="prose prose-img:rounded-xl prose-img:shadow-lg mx-auto dark:prose-invert">
				{heroImage && (
					<img
						width={720}
						height={360}
						src={heroImage}
						alt=""/>
				)}
				<h1 class="title">{title}</h1>
				{pubDate && <span><time>{pubDate}</time> &bull;</span>}
				{author ?? "Aleks Rutins"}
				{updatedDate && <div>Last updated on <time>{updatedDate}</time></div>}
				<hr/>
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
