---
export interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
	extraLarge?: boolean
}

const { href, class: className, extraLarge, ...props } = Astro.props as Props;
const isActive = href === Astro.url.pathname;
---

<a href={href} class:list={[className, { active: isActive }, { 'extra-padding': extraLarge ?? false }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
		text-transform: uppercase;
		padding: 15px 10px;
		transition-property: all;
		transition-duration: .2s;
	}
	a.extra-padding {
		padding: 25px 10px;
	}
	a:hover {
		color: grey;
	}
	a.active {
		font-weight: bolder;
		color: black;
		background-color: white;
	}
</style>
