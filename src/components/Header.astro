---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../config';
---

<header id="site-header" class="transition flex flex-col items-center p-2 w-screen sticky top-[-38px] scroll backdrop-blur-md bg-slate-50/50 dark:bg-gray-900/50 font-[Montserrat]">
	<a href="/" class="block pb-3">
		{SITE_TITLE}
	</a>
	<nav class="font-mono">
		<HeaderLink href="/">Home</HeaderLink>
		<HeaderLink href="/blog">Blog</HeaderLink>
		<HeaderLink href="/about">About</HeaderLink>
		<HeaderLink href="https://github.com/aleksrutins" target="_blank">GitHub</HeaderLink>
	</nav>
</header>
<style>
	header {
		margin: 0em 0 2em;
	}
	h2 {
		margin: 0.5em 0;
	}
</style>

<script>
	const header = document.querySelector('header#site-header');
	window.addEventListener('scroll', (e) => {
		requestAnimationFrame(() => {
			if(window.scrollY > 38) {
				header.classList.add('shadow-md');
			} else {
				header.classList.remove('shadow-md');
			}
		});
	})
</script>